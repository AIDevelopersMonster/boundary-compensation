    },
    "stopping_rule": "one frozen evaluation; no predictor, grid, quotient, threshold or exclusion changes after this commit"
  },
  "claim_firewall": {
    "allowed": "affine-calibration-invariant differential ordering and separation on the declared nonuniform carrier interval",
    "forbidden": [
      "absolute lower-symbol accuracy",
      "invariance under theta-dependent or nonlinear calibration",
      "confirmatory phase law",
      "physical q dynamics"
