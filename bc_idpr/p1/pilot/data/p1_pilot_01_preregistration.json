{
  "schema_version": "1.0",
  "contract": "BC-IDPR-P1-PILOT-01",
  "status": "PREREGISTERED_BEFORE_EVALUATION",
  "date": "2026-07-16",
  "upstream_gate": "BC-IDPR-CERT-02 differential additive-offset quotient only",
  "domain": {
    "theta_interval": ["pi/10", "3*pi/20"],
    "theta_anchor": "pi/8",
    "dense_grid_size": 257,
    "wall_margin": "pi/20"
  },
  "observable_protocol": {
    "source": "frozen M4 coherent-symbol package",
    "active_channels": ["regular_G23", "holdout_G23"],
    "negative_controls": ["regular_G12", "holdout_G12"],
    "complex_signed_observable": "Z(theta)=Q_regular_G23(theta)+i Q_holdout_G23(theta)",
    "differential_quotient": "Q(theta)=S(theta)-S(theta_anchor)",
    "allowed_calibration_group": "theta-independent additive offsets"
  },
  "predictor_models": {
    "phase_model": {
      "basis": [
        "exp(i*theta)-exp(i*theta_anchor)",
        "exp(i*3*theta)-exp(i*3*theta_anchor)",
        "exp(i*5*theta)-exp(i*5*theta_anchor)"
      ],
      "motivation": "odd channel frequencies 1,3,5 in the frozen spin-one operator spectrum",
      "fit": "complex least squares without intercept"
    },
    "smooth_null": {
      "basis": ["x", "x^2", "x^3"],
      "x": "theta-theta_anchor",
      "fit": "complex least squares without intercept"
    }
  },
  "validation": {
    "folds": 8,
    "scheme": "contiguous blocked cross-validation over the ordered dense grid",
    "metric": "held-out complex RMSE normalized by held-out RMS signal",
    "coefficient_stability": "maximum leave-one-fold-out relative coefficient displacement"
  },
  "uncertainty": {
    "arithmetic_bound": 5e-14,
    "finite_difference_used_in_decision": false,
    "decision_margin_multiplier": 10
  },
  "success_criteria": {
    "negative_control_max_abs": 1e-12,
    "phase_model_cv_rmse_ratio_max": 0.05,
    "phase_model_advantage_over_smooth_null_min": 0.10,
    "coefficient_stability_max": 0.25,
    "minimum_signed_excursion": 0.001,
    "stopping_rule": "evaluate once on the frozen 257-point grid; no basis, threshold, fold or channel changes after preregistration"
  },
  "claim_ceiling": {
    "allowed": "exploratory phase-structured differential fit within the declared analytic envelope",
    "forbidden": [
      "confirmatory physical phase law",
      "standard SU(2)_k interpretation away from anchor",
      "absolute symbol accuracy",
      "unequal-area generalization",
      "physical dynamics of q"
    ]
  }
}
